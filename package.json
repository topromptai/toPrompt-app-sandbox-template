    "prettier": "3.4.2",
    "typescript": "5.9.2"
  },
  "pnpm": {
    "overrides": {
      "react": "19.1.0",
      "react-native": "0.81.5",
      "expo": "54.0.33",
      "react-native-reanimated": "4.1.1",
      "react-native-gesture-handler": "2.28.0",
